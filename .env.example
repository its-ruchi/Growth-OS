# Required: Groq API key used only by the backend API service.
GROQ_API_KEY=your_groq_api_key_here

# Required: Supabase (used by backend for JWT verification)
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Required: Supabase (used by the frontend)
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: Require users to be authenticated to call /api/v1/agents/run
REQUIRE_AUTH=true

# Optional: API server port.
API_PORT=8787

# Optional: AI endpoint rate limits (per authenticated user).
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# Optional: AI endpoint rate limits (per client IP address).
IP_RATE_LIMIT_WINDOW_MS=60000
IP_RATE_LIMIT_MAX_REQUESTS=60


# Optional: Max accepted JSON body size for API requests.
REQUEST_BODY_LIMIT=250kb

# Optional: Override frontend API base URL if not using Vite proxy.
# VITE_API_BASE_URL=""
